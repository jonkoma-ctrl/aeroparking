generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CruiseReservation {
  id              String   @id @default(cuid())
  status          String   @default("pending") // pending | confirmed | cancelled

  // Datos del cliente
  firstName       String
  lastName        String
  email           String
  phone           String

  // Datos del viaje
  departureDate   DateTime
  arrivalTime     String   // Hora estimada de llegada al parking
  returnDate      DateTime
  pickupTime      String   // Hora estimada de retiro del auto
  passengers      Int

  // Datos del vehículo
  licensePlate    String
  carBrand        String
  carModel        String

  // Datos opcionales del crucero
  cruiseLine      String?  // Naviera
  terminal        String?

  // Observaciones
  notes           String?

  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AeroparqueReservation {
  id               String   @id @default(cuid())
  externalOrderId  String   @unique
  status           String   @default("confirmed") // confirmed | cancelled | completed

  destination      String   @default("aeroparque") // "aeroparque" | "puerto"
  serviceType      String   // "drop_go" | "larga_estadia"
  customerName     String
  email            String?
  phone            String?
  dni              String?

  // Vehículo
  licensePlate     String
  carBrand         String
  carModel         String

  // Reserva
  startDate        DateTime
  endDate          DateTime
  price            Int      // ARS pesos enteros (214000)

  // Vuelo
  departureFlightDate DateTime?
  departureAirline    String?
  departureFlight     String?
  arrivalAirline      String?
  arrivalFlight       String?
  arrivalTime         String?
  checkInTime         String?
  passengers          Int?

  // Notas
  notes            String?  @db.Text

  // Auditoría
  rawEmailSubject  String?
  rawEmailBody     String?  @db.Text

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
