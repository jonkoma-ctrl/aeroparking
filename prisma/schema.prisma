generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CruiseReservation {
  id              String   @id @default(cuid())
  status          String   @default("pending") // pending | confirmed | cancelled

  // Datos del cliente
  firstName       String
  lastName        String
  email           String
  phone           String

  // Datos del viaje
  departureDate   DateTime
  arrivalTime     String   // Hora estimada de llegada al parking
  returnDate      DateTime
  pickupTime      String   // Hora estimada de retiro del auto
  passengers      Int

  // Datos del vehículo
  licensePlate    String
  carBrand        String
  carModel        String

  // Datos opcionales del crucero
  cruiseLine      String?  // Naviera
  terminal        String?

  // Observaciones
  notes           String?

  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AeroparqueReservation {
  id               String   @id @default(cuid())
  externalOrderId  String   @unique
  status           String   @default("confirmed") // confirmed | cancelled | completed

  destination      String   @default("aeroparque") // "aeroparque" | "puerto"
  serviceType      String   // "drop_go" | "larga_estadia"
  customerName     String
  email            String?
  phone            String?
  dni              String?

  // Vehículo
  licensePlate     String
  carBrand         String
  carModel         String

  // Reserva
  startDate        DateTime
  endDate          DateTime
  price            Int      // ARS pesos enteros (214000)

  // Vuelo
  departureFlightDate DateTime?
  departureAirline    String?
  departureFlight     String?
  arrivalAirline      String?
  arrivalFlight       String?
  arrivalTime         String?
  checkInTime         String?
  passengers          Int?

  // Notas
  notes            String?  @db.Text

  // Auditoría
  rawEmailSubject  String?  // DEPRECATED — legacy AA2000 webhook, sin uso desde may-2026
  rawEmailBody     String?  @db.Text   // DEPRECATED — legacy AA2000 webhook, sin uso desde may-2026

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Destination {
  id            String   @id @default(cuid())
  slug          String   @unique           // "aeroparque" | "ezeiza" | "puerto" | etc.
  label         String                     // "Aeroparque Jorge Newbery"
  shortLabel    String                     // "Aeroparque"
  iconKey       String   @default("plane") // "plane" | "ship" | "bus" — render-side
  accentColor   String   @default("blue")  // tailwind hue (blue, sky, violet, amber)
  description   String?  @db.Text
  addressInfo   String?  @db.Text          // instructivo para el cliente
  imageUrl      String?                    // URL Vercel Blob, imagen principal
  imageAlt      String?                    // alt text para accesibilidad
  active        Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([active, sortOrder])
}

model SiteSettings {
  id              String   @id @default("singleton")
  heroImageUrl    String?
  heroImageAlt    String?
  heroTitle       String?  @db.Text
  heroSubtitle    String?  @db.Text
  whatsappPhone   String?
  contactEmail    String?
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}

model ServicePricing {
  id                  String   @id @default(cuid())
  destination         String   // "puerto" | "aeroparque" | "ezeiza"
  serviceType         String   // "larga_estadia" | "drop_go" | "cruceros" | "ezeiza_larga_estadia"
  pricePerDay         Int      // ARS pesos enteros por estadía completa (24h)
  description         String?
  active              Boolean  @default(true)
  isReference         Boolean  @default(false)  // DEPRECATED — legacy AA2000, sin uso desde may-2026
  externalCheckoutUrl String?                    // DEPRECATED — legacy AA2000, sin uso desde may-2026
  minDays             Int?
  maxDays             Int?
  durationDiscounts   Json?    // [{fromDays, pctOff}]
  transferIncluded    Boolean  @default(true)   // false → cobra traslado aparte (Ezeiza)
  transferCostPerLeg  Int?                       // ARS por tramo de traslado (solo si no incluido)
  updatedAt           DateTime @updatedAt
  createdAt           DateTime @default(now())

  @@unique([destination, serviceType])
}

model CustomerCredit {
  id                  String    @id @default(cuid())
  email               String
  amountAvailable     Int       // ARS pesos
  reason              String?   @db.Text
  sourceReservationId String?   // reserva que originó el crédito (ej: cancelada por vuelo cancelado)
  status              String    @default("available")  // available | used | expired
  usedAt              DateTime?
  usedReservationId   String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([email, status])
}
