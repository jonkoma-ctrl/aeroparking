generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model CruiseReservation {
  id              String   @id @default(cuid())
  status          String   @default("pending") // pending | confirmed | cancelled

  // Datos del cliente
  firstName       String
  lastName        String
  email           String
  phone           String

  // Datos del viaje
  departureDate   DateTime
  arrivalTime     String   // Hora estimada de llegada al parking
  returnDate      DateTime
  pickupTime      String   // Hora estimada de retiro del auto
  passengers      Int

  // Datos del vehículo
  licensePlate    String
  carBrand        String
  carModel        String

  // Datos opcionales del crucero
  cruiseLine      String?  // Naviera
  terminal        String?

  // Observaciones
  notes           String?

  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
