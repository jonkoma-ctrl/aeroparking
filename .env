# =============================================
# ParkBA - Variables de Entorno
# =============================================

# URLs de servicios externos (Aeropuertos Argentina 2000)
NEXT_PUBLIC_VALET_URL=https://tienda.aeropuertosargentina.com/aeroparque/producto/valet-parking/
NEXT_PUBLIC_LONG_STAY_URL=https://tienda.aeropuertosargentina.com/aeroparque/producto/larga-estadia-4-dias-o-mas/

# Base URL del sitio
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Base de datos (SQLite para desarrollo)
DATABASE_URL="file:./dev.db"

# Email de administrador para notificaciones
ADMIN_EMAIL=reservas@nrauditores.com.ar

# Token para autenticar el webhook de integración Aeroparque
# Usá este valor en el header x-integration-token al enviar mails al webhook
AEROPARQUE_MAIL_TOKEN=ap-webhook-2026-secret

# Nombre comercial
NEXT_PUBLIC_BRAND_NAME=AEROPARKING
