# =============================================
# AEROPARKING - Variables de Entorno (dev)
# =============================================
# Producción usa Vercel env vars (vercel env pull para sincronizar).

# Base URL del sitio
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Nombre comercial
NEXT_PUBLIC_BRAND_NAME=AEROPARKING

# Base de datos local (Vercel usa Neon vía DATABASE_URL en .env.local)
DATABASE_URL="file:./dev.db"

# Email administrador (legacy — la fuente actual es Settings.adminNotifyEmail
# en DB, default reservas@nrauditores.com.ar).
ADMIN_EMAIL=admin@aeroparking.com.ar

# Webhook token para integración con mails AA2000 (legacy — mantener mientras
# el webhook /api/integraciones/aeroparque/email siga activo).
AEROPARQUE_MAIL_TOKEN=ap-webhook-2026-secret

# Clave admin (en producción se usa ADMIN_PASSWORD desde Vercel env).
ADMIN_PASSWORD=aeroparking2026
